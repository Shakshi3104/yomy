{
  "env": {
    "APP_ID": "6770222036",
    "PROJECT_PATH": "Yomi.xcodeproj",
    "SCHEME": "Yomi",
    "CONFIGURATION": "Release",
    "EXPORT_OPTIONS": ".asc/export-options.plist",
    "VERSION": ""
  },
  "workflows": {
    "testflight_internal": {
      "description": "Archive yomy, export an IPA, and upload to TestFlight for internal testing. Build number is auto-managed by the Xcode Run Script phase (git commit count).",
      "steps": [
        {
          "name": "validate_version",
          "run": "if [ -z \"$VERSION\" ]; then echo \"VERSION is required (e.g. asc workflow run testflight_internal VERSION:1.0)\" >&2; exit 1; fi"
        },
        {
          "name": "archive",
          "run": "asc xcode archive --project \"$PROJECT_PATH\" --scheme \"$SCHEME\" --configuration \"$CONFIGURATION\" --archive-path \".asc/artifacts/yomy-$VERSION.xcarchive\" --clean --overwrite --xcodebuild-flag=-destination --xcodebuild-flag=generic/platform=iOS --xcodebuild-flag=-allowProvisioningUpdates --xcodebuild-flag=MARKETING_VERSION=$VERSION --output json",
          "outputs": {
            "ARCHIVE_PATH": "$.archive_path"
          }
        },
        {
          "name": "export",
          "run": "asc xcode export --archive-path ${steps.archive.ARCHIVE_PATH} --export-options \"$EXPORT_OPTIONS\" --ipa-path \".asc/artifacts/yomy-$VERSION.ipa\" --overwrite --xcodebuild-flag=-allowProvisioningUpdates --output json",
          "outputs": {
            "IPA_PATH": "$.ipa_path"
          }
        },
        {
          "name": "publish",
          "run": "asc publish testflight --app \"$APP_ID\" --ipa ${steps.export.IPA_PATH} --wait --output json"
        }
      ]
    }
  }
}
